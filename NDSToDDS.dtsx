                          dataType="i4"
                          errorOrTruncationOperation="Conversion"
                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\Sequence Container\Populate Sales Fact\Source.Outputs[OLE DB Source Output].ExternalColumns[StoreID]"
                          lineageId="Package\Sequence Container\Populate Sales Fact\Source.Outputs[OLE DB Source Output].Columns[StoreID]"
                          name="StoreID"
                          truncationRowDisposition="FailComponent" />
                        <outputColumn
                          refId="Package\Sequence Container\Populate Sales Fact\Source.Outputs[OLE DB Source Output].Columns[SaleDate]"
